generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum AdminRole {
  REVIEWER
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  role        UserRole  @default(USER)
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  isVerified     Boolean   @default(false)

  deletedAt DateTime? // soft delete field

  admin        Admin?
  projectOwner ProjectOwner?
}

model Admin {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  user      User      @relation(fields: [userId], references: [id])
  adminRole AdminRole @default(REVIEWER)
}

model ProjectOwner {
  id                 Int        @id @default(autoincrement())
  userId             Int        @unique
  user               User       @relation(fields: [userId], references: [id])
  name               String
  organization       String
  location           String?
  position           String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  submittedProposals Proposal[]
  approvedProjects   Project[]
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Proposal {
  id String @id @default(uuid())

  proposalStatus ProposalStatus @default(PENDING)
  project        Project?

  projectTitle        String
  organization        String
  contactPerson       String
  location            String
  sector              String
  startDate           DateTime
  endDate             DateTime
  stage               String
  estimatedInvestment Int
  currency            String
  partners            String
  genderDetails       String?

  projectOverview Json

  categories      Json
  categoriesOther String

  envImpact            Json
  envImpactIndicator   String
  envImpactDescription String

  socialImpact            Json
  socialImpactDescription String

  compliance          Json
  fundingOptions      Json
  fundingOptionsOther String
  totalCost           Int
  fundingSought       Json
  scalable            String

  measureableImpact Boolean
  annualReporting   Boolean
  keyIndicators     Boolean
  monitoring        Boolean

  companyRegistration Json?
  businessPlan        Json?
  financialStatements Json?
  partnerships        Json?
  techStudies         Json?
  other               Json?

  signedName String
  position   String

  comments Json? // stores list of comments

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  projectOwner   ProjectOwner? @relation(fields: [projectOwnerId], references: [id])
  projectOwnerId Int?
}

model Project {
  id         String    @id @default(uuid())
  proposalId String?   @unique
  proposal   Proposal? @relation(fields: [proposalId], references: [id])

  projectTitle        String
  organization        String
  contactPerson       String
  location            String
  sector              String
  startDate           DateTime
  endDate             DateTime
  stage               String
  estimatedInvestment Int
  currency            String
  partners            String
  genderDetails       String?
  projectOverview     Json

  categories      Json
  categoriesOther String?

  envImpact            Json
  envImpactIndicator   String
  envImpactDescription String

  socialImpact            Json
  socialImpactDescription String

  compliance          Json
  fundingOptions      Json
  fundingOptionsOther String?
  totalCost           Int
  fundingSought       Json
  scalable            String

  measureableImpact Boolean
  annualReporting   Boolean
  keyIndicators     Boolean
  monitoring        Boolean

  companyRegistration Json?
  businessPlan        Json?
  financialStatements Json?
  partnerships        Json?
  techStudies         Json?
  other               Json?

  signedName String
  position   String

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  projectOwner   ProjectOwner? @relation(fields: [projectOwnerId], references: [id])
  projectOwnerId Int?
}

