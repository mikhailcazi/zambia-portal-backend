// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Proposal {
  id                   String       @id @default(uuid())

  proposalStatus       ProposalStatus  @default(PENDING)
  project              Project?

  projectTitle         String
  organization         String
  contactPerson        String
  location             String
  sector               String
  startDate            DateTime
  endDate              DateTime
  stage                String
  estimatedInvestment  Int
  currency             String
  partners             String
  genderDetails        String?

  projectOverview      Json

  categories           Json
  categoriesOther      String

  envImpact            Json
  envImpactIndicator   String
  envImpactDescription String

  socialImpact         Json
  socialImpactDescription String

  compliance           Json
  fundingOptions       Json
  fundingOptionsOther  String
  totalCost            Int
  fundingSought        Json
  scalable             String

  measureableImpact    Boolean
  annualReporting      Boolean
  keyIndicators        Boolean
  monitoring           Boolean

  companyRegistration  Json?
  businessPlan         Json?
  financialStatements  Json?
  partnerships         Json?
  techStudies          Json?
  other                Json?

  signedName           String
  position             String

  comments             Json?    // stores list of comments

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Project {
  id          String   @id @default(uuid())
  proposalId  String?   @unique
  proposal    Proposal? @relation(fields: [proposalId], references: [id])

  projectTitle         String
  organization         String
  contactPerson        String
  location             String
  sector               String
  startDate            DateTime
  endDate              DateTime
  stage                String
  estimatedInvestment  Int
  currency             String
  partners             String
  genderDetails        String?
  projectOverview      Json

  categories           Json
  categoriesOther      String?

  envImpact            Json
  envImpactIndicator   String
  envImpactDescription String

  socialImpact         Json
  socialImpactDescription String

  compliance           Json
  fundingOptions       Json
  fundingOptionsOther  String?
  totalCost            Int
  fundingSought        Json
  scalable             String

  measureableImpact    Boolean
  annualReporting      Boolean
  keyIndicators        Boolean
  monitoring           Boolean

  companyRegistration  Json?
  businessPlan         Json?
  financialStatements  Json?
  partnerships         Json?
  techStudies          Json?
  other                Json?

  signedName           String
  position             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminRole {
  REVIEWER
}

model Admin {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  password  String
  name      String?
  role      AdminRole  @default(REVIEWER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}